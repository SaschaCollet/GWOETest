---
import { useStoryblokApi } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const storyblokApi = useStoryblokApi();
  // Lokal (astro dev) immer Draft für Live-Vorschau von Änderungen; in der Produktions-
  // Build (z.B. auf Netlify) nur veröffentlichte Inhalte, damit unveröffentlichte Entwürfe
  // nicht öffentlich sichtbar werden.
  const { data } = await storyblokApi.get('cdn/stories', {
    version: import.meta.env.PROD ? 'published' : 'draft',
  });

  return data.stories.map((story: any) => ({
    params: { slug: story.full_slug === 'home' ? undefined : story.full_slug },
    props: { story },
  }));
}

const { story } = Astro.props;
---

<BaseLayout title={story.name}>
  <StoryblokComponent blok={story.content} />
</BaseLayout>
