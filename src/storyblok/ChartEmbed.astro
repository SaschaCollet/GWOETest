---
import { storyblokEditable } from '@storyblok/astro';

interface Props {
  blok: {
    title?: string;
    embed_code?: string;
    caption?: string;
    alt_text?: string;
    [key: string]: unknown;
  };
}

const { blok } = Astro.props;
---

<figure {...storyblokEditable(blok)} class="chart-embed container">
  {blok.title && <h2>{blok.title}</h2>}

  {
    blok.embed_code ? (
      <div class="chart-embed__frame" role="img" aria-label={blok.alt_text || blok.title || 'Diagramm'}>
        <Fragment set:html={blok.embed_code} />
      </div>
    ) : (
      <p class="chart-embed__placeholder">
        Noch kein Diagramm hinterlegt — Embed-Code in Storyblok eintragen.
      </p>
    )
  }

  {blok.caption && <figcaption>{blok.caption}</figcaption>}
</figure>

<style>
  .chart-embed {
    padding-block: var(--space-12);
  }

  .chart-embed__frame {
    margin-top: var(--space-4);
    min-height: 20rem;
    aspect-ratio: 16 / 9;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .chart-embed__frame :global(iframe) {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .chart-embed__placeholder {
    margin-top: var(--space-4);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
  }

  figcaption {
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }
</style>
