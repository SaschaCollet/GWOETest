---
import { storyblokEditable, renderRichText } from '@storyblok/astro';

interface Props {
  blok: {
    _uid: string;
    name: string;
    x_position: number;
    y_position: number;
    description?: unknown;
    color?: string;
    [key: string]: unknown;
  };
}

const { blok } = Astro.props;
const html = blok.description ? renderRichText(blok.description as never) : '';
const left = Math.min(100, Math.max(0, Number(blok.x_position) || 0));
const top = 100 - Math.min(100, Math.max(0, Number(blok.y_position) || 0));
---

<button
  {...storyblokEditable(blok)}
  type="button"
  class="matrix-topic"
  style={`left:${left}%; top:${top}%; --point-color:${blok.color || 'var(--color-primary)'};`}
  data-matrix-topic={blok._uid}
  aria-expanded="false"
  aria-controls="materiality-detail"
>
  <span class="visually-hidden">{blok.name} — Details anzeigen</span>
</button>

<template data-matrix-template={blok._uid}>
  <h3>{blok.name}</h3>
  <div set:html={html} />
</template>

<style>
  .matrix-topic {
    position: absolute;
    width: 1rem;
    height: 1rem;
    margin: -0.5rem;
    padding: 0;
    border-radius: var(--radius-full);
    border: 2px solid var(--color-background);
    background: var(--point-color, var(--color-primary));
    box-shadow: var(--shadow-sm);
    cursor: pointer;
  }

  .matrix-topic:hover {
    transform: scale(1.2);
  }

  .matrix-topic[aria-expanded='true'] {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
