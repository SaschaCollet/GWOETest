---
import ScrollProgress from './ScrollProgress.astro';
import Logo from './Logo.astro';

interface Chapter {
  id: string;
  label: string;
}

interface Props {
  chapters: Chapter[];
  reportTitle?: string;
  logoSrc?: string;
}

const { chapters, reportTitle = 'Nachhaltigkeitsbericht 2025', logoSrc } = Astro.props;
---

<header class="site-header">
  <nav class="site-nav" aria-label="Kapitel-Navigation">
    <div class="site-nav__bar container">
      <a href="#main-content" class="site-nav__brand">
        <Logo fallbackText={reportTitle} height="2rem" src={logoSrc} />
      </a>

      <button
        type="button"
        class="site-nav__toggle"
        id="nav-toggle"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <span class="visually-hidden">Menü öffnen</span>
        <span aria-hidden="true">☰</span>
      </button>

      <ul role="list" class="site-nav__menu" id="nav-menu">
        {
          chapters.map((chapter) => (
            <li>
              <a href={`#${chapter.id}`}>{chapter.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
  <ScrollProgress />
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--color-background);
    box-shadow: var(--shadow-sm);
  }

  .site-nav__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-3);
  }

  .site-nav__brand {
    font-family: var(--font-heading);
    font-weight: bold;
    text-decoration: none;
    color: var(--color-text);
  }

  .site-nav__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-background);
    font-size: 1.25rem;
    cursor: pointer;
  }

  .site-nav__menu {
    display: none;
    flex-direction: column;
    gap: var(--space-2);
  }

  .site-nav__menu a {
    display: block;
    padding: var(--space-2) 0;
    text-decoration: none;
    color: var(--color-text);
  }

  .site-nav__menu a:hover {
    color: var(--color-primary);
  }

  .site-nav__menu.is-open {
    display: flex;
    position: absolute;
    inset-inline: 0;
    top: 100%;
    padding: var(--space-4);
    background: var(--color-background);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .site-nav__toggle {
      display: none;
    }

    .site-nav__menu {
      display: flex;
      flex-direction: row;
      gap: var(--space-6);
      position: static;
      padding: 0;
      border: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    menu.addEventListener('click', (event) => {
      if ((event.target as HTMLElement).tagName === 'A') {
        menu.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && menu.classList.contains('is-open')) {
        menu.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.focus();
      }
    });
  }
</script>
